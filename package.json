    "ai:controller": "bash -lc 'set -a; [ -f .env ] && . ./.env; [ -f local.env ] && . ./local.env; set +a; node server/ai_controller.js'",
    "servers:start": "bash server/start_servers.sh"
  },
  "dependencies": {
